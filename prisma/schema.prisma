generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Movie {
  id          Int            @id
  title       String
  year        Int?
  genres      String[]
  avgRating   Float          @default(0)
  ratingCount Int            @default(0)
  clickCount  Int            @default(0)
  ratings     Rating[]
  similar     CFSimilarity[] @relation("MovieSimilar")
  sessions    UserSession[]
}

model Rating {
  userId  Int
  movieId Int
  score   Float
  movie   Movie @relation(fields: [movieId], references: [id])

  @@unique([userId, movieId])
  @@index([movieId])
}

model CFSimilarity {
  movieId        Int
  similarMovieId Int
  score          Float
  movie          Movie @relation("MovieSimilar", fields: [movieId], references: [id])

  @@unique([movieId, similarMovieId])
  @@index([movieId, score(sort: Desc)])
}

model UserSession {
  id        Int      @id @default(autoincrement())
  sessionId String
  movieId   Int
  timestamp DateTime @default(now())
  movie     Movie    @relation(fields: [movieId], references: [id])

  @@index([timestamp])
  @@index([movieId])
}
